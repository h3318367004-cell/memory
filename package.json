{
  "name": "codex-memory-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Codex-only Cloudflare-native memory kernel with Worker, D1, local MCP, DeepSeek dream, and Zhipu embeddings.",
  "main": "src/mcp-server.js",
  "scripts": {
    "mcp": "node ./src/mcp-server.js",
    "db:migrate": "wrangler d1 execute codex-memory --remote --file ./worker/schema.sql",
    "worker:dev": "wrangler dev --config ./worker/wrangler.toml",
    "worker:dry-run": "wrangler deploy --config ./worker/wrangler.toml --dry-run",
    "worker:deploy": "wrangler deploy --config ./worker/wrangler.toml",
    "import:local": "node ./scripts/import-local.js",
    "check": "node --check ./src/mcp-server.js && node --check ./scripts/import-local.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
